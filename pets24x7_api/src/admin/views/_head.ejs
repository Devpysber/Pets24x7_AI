<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title : 'Pets24x7 Admin' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    :root{--primary:#2563EB;--primary-dark:#1D4ED8;--bg:#F9FAFB;--text:#1F2937;--muted:#6B7280;--border:#E5E7EB;--success:#10B981;--danger:#DC2626;--warning:#F59E0B;}
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Inter',sans-serif;color:var(--text);background:var(--bg);font-size:14px;line-height:1.5}
    a{color:var(--primary);text-decoration:none}a:hover{text-decoration:underline}
    .layout{display:grid;grid-template-columns:240px 1fr;min-height:100vh}
    .side{background:#0F172A;color:#CBD5E1;padding:24px 16px}
    .side h1{color:#fff;font-size:18px;margin-bottom:24px;font-weight:800;letter-spacing:-0.3px}
    .side nav a{display:block;color:#CBD5E1;padding:10px 12px;border-radius:8px;font-weight:500;margin-bottom:4px}
    .side nav a:hover{background:#1E293B;color:#fff;text-decoration:none}
    .side nav a.active{background:var(--primary);color:#fff}
    .main{padding:32px 36px}
    .page-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;flex-wrap:wrap;gap:12px}
    .page-head h2{font-size:24px;font-weight:800;letter-spacing:-0.4px}
    .card{background:#fff;border:1px solid var(--border);border-radius:12px;padding:24px;box-shadow:0 1px 2px rgba(0,0,0,0.04)}
    .stat-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;margin-bottom:24px}
    .stat-card{background:#fff;border:1px solid var(--border);border-radius:12px;padding:20px}
    .stat-card .lbl{font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px;font-weight:600}
    .stat-card .num{font-size:30px;font-weight:800;color:var(--text);margin-top:4px}
    table{width:100%;border-collapse:collapse;font-size:13px}
    th{text-align:left;padding:10px 12px;background:#F9FAFB;border-bottom:1px solid var(--border);font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:0.5px;color:var(--muted)}
    td{padding:12px;border-bottom:1px solid var(--border);vertical-align:top}
    tr:hover td{background:#FAFBFC}
    .pill{display:inline-block;padding:2px 8px;border-radius:999px;font-size:11px;font-weight:700}
    .pill.pending{background:#FEF3C7;color:#92400E}
    .pill.active,.pill.success{background:#DCFCE7;color:#166534}
    .pill.rejected,.pill.failed,.pill.cancelled{background:#FEE2E2;color:#991B1B}
    .pill.suspended,.pill.refunded{background:#F3E8FF;color:#6B21A8}
    .pill.initiated{background:#DBEAFE;color:#1E40AF}
    .pill.expired{background:#F3F4F6;color:#6B7280}
    .btn{display:inline-block;padding:8px 14px;border-radius:8px;font-weight:600;font-size:13px;border:1px solid var(--border);background:#fff;color:var(--text);cursor:pointer;text-decoration:none}
    .btn:hover{background:#F9FAFB;text-decoration:none}
    .btn-primary{background:var(--primary);color:#fff;border-color:var(--primary)}
    .btn-primary:hover{background:var(--primary-dark);color:#fff}
    .btn-success{background:var(--success);color:#fff;border-color:var(--success)}
    .btn-danger{background:var(--danger);color:#fff;border-color:var(--danger)}
    .btn-sm{padding:5px 10px;font-size:12px}
    .row{display:flex;gap:8px;align-items:center;flex-wrap:wrap}
    .muted{color:var(--muted)}
    .empty{padding:48px 16px;text-align:center;color:var(--muted)}
    form.inline{display:inline}
    .filters{display:flex;gap:8px;margin-bottom:16px}
    .filters a{padding:6px 12px;border-radius:8px;background:#fff;border:1px solid var(--border);font-weight:600;font-size:13px;color:var(--text)}
    .filters a.active{background:var(--primary);color:#fff;border-color:var(--primary)}
    input[type=email],input[type=password],input[type=text]{width:100%;padding:10px 12px;border:1px solid var(--border);border-radius:8px;font-family:inherit;font-size:14px;background:#fff}
    input:focus{outline:none;border-color:var(--primary);box-shadow:0 0 0 3px rgba(37,99,235,0.12)}
    label{display:block;font-size:12px;color:var(--muted);font-weight:600;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px}
    @media(max-width:760px){.layout{grid-template-columns:1fr}.side{display:none}}
  </style>
</head>
<body>
<% if (typeof active !== 'undefined') { %>
<div class="layout">
  <aside class="side">
    <h1>Pets24x7 <span style="color:#60A5FA">Admin</span></h1>
    <nav>
      <a href="/admin/dashboard"   class="<%= active === 'dashboard'   ? 'active' : '' %>">Dashboard</a>
      <a href="/admin/vendors"     class="<%= active === 'vendors'     ? 'active' : '' %>">Vendors</a>
      <a href="/admin/parents"     class="<%= active === 'parents'     ? 'active' : '' %>">Pet Parents</a>
      <a href="/admin/memberships" class="<%= active === 'memberships' ? 'active' : '' %>">Memberships</a>
      <a href="/admin/payments"    class="<%= active === 'payments'    ? 'active' : '' %>">Payments</a>
      <a href="/admin/reviews"     class="<%= active === 'reviews'     ? 'active' : '' %>">Reviews</a>
      <a href="/admin/enquiries"   class="<%= active === 'enquiries'   ? 'active' : '' %>">Enquiries</a>
      <form action="/admin/logout" method="post" style="margin-top:24px;">
        <button class="btn" type="submit" style="width:100%;background:transparent;border-color:#334155;color:#CBD5E1">Logout</button>
      </form>
    </nav>
  </aside>
  <main class="main">
<% } %>
