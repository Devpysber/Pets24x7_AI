# Pets24x7 API — copy to .env and fill in.

# ---- Runtime ----
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# Public URLs (used in CORS, redirects, OG embeds)
PUBLIC_SITE_URL=https://pets24x7.com
PUBLIC_API_URL=https://api.pets24x7.com

# ---- Postgres (Supabase) ----
# Get from Supabase project > Settings > Database > Connection string > URI
DATABASE_URL="postgresql://postgres:PASSWORD@db.xxxxxxxxxxxx.supabase.co:5432/postgres?schema=public"

# ---- Auth ----
# Long random string. Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me-to-96-random-hex-chars"
JWT_ISSUER="pets24x7.com"
COOKIE_DOMAIN=".pets24x7.com"
ADMIN_SESSION_SECRET="another-96-random-hex-chars"

# ---- WhatsApp Cloud API (Meta) ----
# https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
WA_PHONE_NUMBER_ID="123456789012345"
WA_BUSINESS_ACCOUNT_ID="123456789012345"
WA_ACCESS_TOKEN="EAAxxxxxxxxxxxxxxxx"
WA_VERIFY_TOKEN="any-random-string-you-pick"
WA_OTP_TEMPLATE_NAME="pets24x7_otp"
WA_OTP_TEMPLATE_LANG="en"
# Phase 3.1 — vendor review-request template (must be approved separately in WA Manager)
WA_REVIEW_TEMPLATE_NAME="pets24x7_review_request"
WA_REVIEW_TEMPLATE_LANG="en"
# Public short-link domain — used in the WA message body. Frontend serves /r/:code.
PUBLIC_SHORTLINK_BASE="https://pets24x7.com"

# ---- Static-site data (frontend repo) ----
# Path to the frontend's data/ folder for phone-match listing lookup.
# Defaults to ../pets24x7_new/data when running locally.
STATIC_DATA_DIR="../pets24x7_new/data"

# ---- PhonePe Payment Gateway ----
# Sandbox creds: https://developer.phonepe.com/v1/docs/uat-testing/
# Production: get keys from https://business.phonepe.com → Developer Settings
PHONEPE_MODE="sandbox"                                # "sandbox" | "production"
PHONEPE_MERCHANT_ID="PGTESTPAYUAT"                    # sandbox default
PHONEPE_SALT_KEY="099eb0cd-02cf-4e2a-8aca-3e6c6aff0399"
PHONEPE_SALT_INDEX=1
PHONEPE_REDIRECT_URL="http://localhost:8000/membership/return/"
PHONEPE_CALLBACK_URL="http://localhost:4000/api/payments/phonepe/callback"

# ---- Bootstrap admin (used by `npm run seed:admin`) ----
SEED_ADMIN_EMAIL="founder@pets24x7.com"
SEED_ADMIN_PASSWORD="change-me-strong-password"
SEED_ADMIN_NAME="Pets24x7 Founder"
